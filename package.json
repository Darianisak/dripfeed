{
  "type": "module",
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "3.7.4",
    "web-ext": "^9.2.0"
  },
  "scripts": {
    "test": "jest --color --config ./jest.config.js --passWithNoTests",
    "firefox": "npx web-ext run --source-dir ./extension/",
    "build": "npx web-ext build --source-dir ./extension/ --artifacts-dir ./build",
    "format": "prettier --check --config ./.prettierrc --write .",
    "lint": "npx eslint --color --fix --config eslint.config.mjs .",
    "yaml": "source pydeps/bin/activate && yamllint --config-file .yamllint --strict .",
    "rubocop": "./bin/bundle exec rubocop --autocorrect --raise-cop-error --extra-details --config ./.rubocop.yml .",
    "rspec": "./bin/bundle exec rspec",
    "sinatra": "./bin/bundle exec ruby sinatra.rb",
    "watch": "npx webpack --mode development --watch",
    "webpack": "npx webpack --mode production",
    "semgrap": "source pydeps/bin/activate && semgrep scan ."
  },
  "dependencies": {
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
